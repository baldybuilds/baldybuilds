---
import Button from '@/components/ui/Button.astro';

const points = [
  {
    title: 'You choose the pages',
    body: 'Anywhere from 1 to 10 pages. You only pay for what your business actually needs.',
    icon: '<path d="M4 4h10M4 8h7M4 12h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
  },
  {
    title: 'Add what you need',
    body: 'Contact form, image gallery, logo design, domain registration. Pick your add-ons and the price updates live.',
    icon: '<path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
  },
  {
    title: 'One flat monthly fee',
    body: '£40/mo covers hosting, domain, SSL, security updates, and up to 1hr of edits every month.',
    icon: '<rect x="3" y="5" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M3 9h12" stroke="currentColor" stroke-width="1.5"/>',
  },
];
---

<section class="section-padding border-t border-border">
  <div class="container">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12" data-animate>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-accent mb-3">Pricing</p>
        <h2 class="font-display font-bold text-[clamp(1.75rem,3.5vw,2.75rem)] text-text">
          Pricing built around you
        </h2>
        <p class="text-muted mt-2 max-w-md">No fixed packages. No paying for things you don't need. Build your quote and see your price in real time.</p>
      </div>
      <Button href="/services" variant="outline" phEvent="cta_click" phProps='{"location":"services_teaser","label":"Build your quote"}'>Build your quote</Button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {points.map((point, i) => (
        <div
          class="flex flex-col gap-4 rounded-[--radius-card] border border-border bg-surface p-6"
          data-animate="scale"
          data-delay={String(i + 1)}
        >
          <div class="w-10 h-10 rounded-lg bg-surface-2 flex items-center justify-center text-accent shrink-0">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" set:html={point.icon} aria-hidden="true" />
          </div>
          <div>
            <h3 class="font-display font-semibold text-text mb-1">{point.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{point.body}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="text-xs text-muted-2 text-center mt-6" data-animate data-delay="4">
      Minimum 3-month term. Prices include VAT.
    </p>
  </div>
</section>
