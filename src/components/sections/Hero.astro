---
---

<section class="relative min-h-[92dvh] flex items-center overflow-hidden">
  <!-- Background grid -->
  <div
    class="absolute inset-0 opacity-[0.035]"
    aria-hidden="true"
    style="background-image: linear-gradient(var(--color-text) 1px, transparent 1px), linear-gradient(90deg, var(--color-text) 1px, transparent 1px); background-size: 60px 60px;"
  ></div>

  <!-- Ambient glow -->
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] rounded-full pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(245,158,11,0.12), transparent 70%); animation: glow-pulse 4s ease-in-out infinite;"
    aria-hidden="true"
  ></div>

  <div class="container relative py-24 lg:py-0 lg:min-h-[92dvh] lg:flex lg:items-center">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center w-full">

      <!-- ── Left column ─────────────────────────────────── -->
      <div>
        <!-- Eyebrow -->
        <div data-animate data-delay="1">
          <p class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.15em] text-accent mb-6">
            <span class="w-6 h-px bg-accent"></span>
            Web design for local business
            <span class="w-6 h-px bg-accent"></span>
          </p>
        </div>

        <!-- Headline -->
        <div data-animate data-delay="2">
          <h1 class="font-display font-bold text-[clamp(2.75rem,5.5vw,5rem)] leading-[1.04] tracking-tight text-text mb-6">
            Your business<br />deserves better<br />than a <span class="text-accent">Facebook<br class="lg:hidden" /> page.</span>
          </h1>
        </div>

        <!-- Sub -->
        <div data-animate data-delay="3">
          <p class="text-lg text-muted max-w-xl mb-10 leading-relaxed">
            BaldyBuilds creates professional, fast websites for tradespeople and small local businesses in Ayrshire. Fixed pricing. Everything included. You never have to think about it again.
          </p>
        </div>

        <!-- CTAs -->
        <div data-animate data-delay="4" class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-12">
          <a
            href="/contact"
            class="btn-shimmer inline-flex items-center gap-2 bg-accent text-black font-semibold text-base rounded-lg px-8 py-4 hover:bg-accent-hover transition-colors active:scale-[0.98]"
            data-ph-event="cta_click"
            data-ph-props='{"location":"hero","label":"Get a free quote"}'
          >
            Get a free quote
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a
            href="/portfolio"
            class="inline-flex items-center gap-2 text-base font-medium text-muted hover:text-text transition-colors group"
            data-ph-event="cta_click"
            data-ph-props='{"location":"hero","label":"See our work"}'
          >
            See our work
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="transition-transform group-hover:translate-x-0.5"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <!-- Trust strip -->
        <div data-animate data-delay="5" class="flex flex-wrap items-center gap-x-6 gap-y-3">
          {[
            'Based in Ayrshire',
            'Fixed, transparent pricing',
            'No jargon, no surprises',
            'Mobile-first every time',
          ].map((item) => (
            <span class="flex items-center gap-2 text-sm text-muted">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <circle cx="7" cy="7" r="7" fill="var(--color-accent)" fill-opacity="0.15"/>
                <path d="M4 7l2 2 4-4" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {item}
            </span>
          ))}
        </div>
      </div>

      <!-- ── Right column — floating cards ──────────────── -->
      <div class="hidden lg:block relative h-[520px]" aria-hidden="true">

        <!-- Card 1: Timeline -->
        <div
          class="absolute top-0 right-8 w-64 rounded-2xl border border-border bg-surface p-5 shadow-2xl"
          style="--float-rotate: -2deg; animation: float 6s ease-in-out infinite; animation-delay: 0s; transform: rotate(-2deg);"
          data-animate="fade"
          data-delay="3"
        >
          <p class="text-xs font-semibold uppercase tracking-widest text-muted mb-3">Typical timeline</p>
          <div class="flex flex-col gap-2">
            {[
              { step: 'Enquiry', days: 'Day 1' },
              { step: 'Design approved', days: 'Day 5–7' },
              { step: 'Build complete', days: 'Day 10–14' },
              { step: 'Go live 🎉', days: 'Day 14–21' },
            ].map(({ step, days }, i) => (
              <div class="flex items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                  <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${i === 3 ? 'bg-accent' : 'bg-border'}`}></span>
                  <span class="text-sm text-text">{step}</span>
                </div>
                <span class="text-xs text-muted shrink-0">{days}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Card 2: Pricing -->
        <div
          class="absolute top-44 left-0 w-60 rounded-2xl border border-accent/30 bg-surface p-5 shadow-2xl"
          style="--float-rotate: 1.5deg; animation: float 7s ease-in-out infinite; animation-delay: -2s; transform: rotate(1.5deg);"
          data-animate="fade"
          data-delay="4"
        >
          <p class="text-xs font-semibold uppercase tracking-widest text-muted mb-3">Starting from</p>
          <div class="flex items-baseline gap-1 mb-1">
            <span class="font-display font-bold text-4xl text-text">£600</span>
            <span class="text-sm text-muted">setup</span>
          </div>
          <p class="text-sm text-muted">then <strong class="text-accent">£35/mo</strong> all-inclusive</p>
          <div class="mt-3 pt-3 border-t border-border flex flex-col gap-1.5">
            {['Hosting & domain', 'SSL certificate', 'Monthly updates'].map((f) => (
              <span class="flex items-center gap-2 text-xs text-muted">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l2.5 2.5 5.5-5" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {f}
              </span>
            ))}
          </div>
        </div>

        <!-- Card 3: Client quote -->
        <div
          class="absolute bottom-0 right-4 w-68 rounded-2xl border border-border bg-surface p-5 shadow-2xl"
          style="--float-rotate: -1deg; animation: float 8s ease-in-out infinite; animation-delay: -4s; transform: rotate(-1deg); width: 272px;"
          data-animate="fade"
          data-delay="5"
        >
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-full bg-accent/20 flex items-center justify-center shrink-0">
              <span class="text-sm font-bold text-accent">DK</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-text">DMK Roofing</p>
              <p class="text-xs text-muted">Ayrshire</p>
            </div>
            <div class="ml-auto flex gap-0.5">
              {[...Array(5)].map(() => (
                <svg width="12" height="12" viewBox="0 0 12 12" fill="var(--color-accent)"><path d="M6 1l1.3 2.6 2.9.4-2.1 2 .5 2.9L6 7.5 3.4 8.9l.5-2.9-2.1-2 2.9-.4z"/></svg>
              ))}
            </div>
          </div>
          <p class="text-sm text-muted leading-relaxed italic">"Up and running from day one. Jamie handled everything. I just had to approve the design."</p>
        </div>

        <!-- Vertical accent line -->
        <div class="absolute top-12 left-[calc(50%-1px)] w-px h-32 bg-linear-to-b from-transparent via-border to-transparent"></div>
      </div>

    </div>
  </div>
</section>
