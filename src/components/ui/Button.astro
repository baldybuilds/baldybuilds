---
interface Props {
  variant?: 'primary' | 'outline' | 'ghost';
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
  phEvent?: string;
  phProps?: string;
  target?: string;
  rel?: string;
}

const {
  variant = 'primary',
  href,
  type = 'button',
  class: className = '',
  phEvent,
  phProps,
  target,
  rel,
} = Astro.props;

const base = 'inline-flex items-center gap-2 font-semibold text-sm rounded-lg px-6 py-3 transition-all duration-200 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent';

const variants = {
  primary: 'bg-accent text-black hover:bg-accent-hover active:scale-[0.98]',
  outline: 'border border-border text-text hover:border-accent hover:text-accent',
  ghost: 'text-muted hover:text-text',
};

const classes = `${base} ${variants[variant]} ${className}`;
---

{href ? (
  <a
    href={href}
    class={classes}
    data-ph-event={phEvent}
    data-ph-props={phProps}
    target={target}
    rel={rel}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    class={classes}
    data-ph-event={phEvent}
    data-ph-props={phProps}
  >
    <slot />
  </button>
)}
