---
import PageLayout from '@/layouts/PageLayout.astro';
import ContactForm from '@/components/sections/ContactForm.astro';
---

<PageLayout
  title="Contact"
  description="Get in touch with BaldyBuilds. Tell us about your business and we'll have a proposal back within 24 hours."
>
  <section class="section-padding">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <!-- Left: header + info -->
        <div class="lg:sticky lg:top-24">
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-accent mb-4">Get in touch</p>
          <h1 class="font-display font-bold text-[clamp(2.25rem,4vw,3.5rem)] text-text mb-4">
            Let's build something together
          </h1>
          <p class="text-lg text-muted mb-10 leading-relaxed">
            Tell me a bit about your business and what you need. No commitment. I'll come back to you with a proposal and we can take it from there.
          </p>

          <!-- Contact details -->
          <div class="flex flex-col gap-5">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-lg bg-surface border border-border flex items-center justify-center text-accent shrink-0">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <rect x="1" y="3" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M1 6l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-muted mb-0.5">Email</p>
                <a href="mailto:hello@baldybuilds.co.uk" class="text-sm text-text hover:text-accent transition-colors">
                  hello@baldybuilds.co.uk
                </a>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-lg bg-surface border border-border flex items-center justify-center text-accent shrink-0">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M9 2C6.239 2 4 4.239 4 7c0 3.75 5 9 5 9s5-5.25 5-9c0-2.761-2.239-5-5-5z" stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="9" cy="7" r="1.5" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-muted mb-0.5">Location</p>
                <p class="text-sm text-text">Ayrshire, Scotland</p>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-lg bg-surface border border-border flex items-center justify-center text-accent shrink-0">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M9 5v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-muted mb-0.5">Response time</p>
                <p class="text-sm text-text">Within 24 hours</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: form -->
        <div class="bg-surface border border-border rounded-2xl p-6 md:p-8">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>
</PageLayout>
